{
  "name": "Analyze Malicious Hash and Create Alert",
  "description": "This workflow analyzes a hash using VirusTotal and creates an alert in TheHive if the hash is found to be malicious.",
  "start": "webhook_trigger",
  "triggers": [
    {
      "id": "ee78f75d-b1f5-40f4-8b05-6dea25b695b6",
      "name": "Wazuh Webhook",
      "app_name": "Shuffle Tools",
      "app_version": "1.2.0",
      "trigger_type": "WEBHOOK",
      "label": "Wazuh Alert Webhook",
      "status": "running"
    }
  ],
  "actions": [
    {
      "id": "8875af4a-eeee-406f-a10b-362fa203badd",
      "name": "get_a_hash_report_",
      "label": "Check VirusTotal",
      "app_name": "Virustotal_v3",
      "app_version": "1.1.0",
      "app_id": "fa9d7dd6d5e501798870c9451611817f",
      "action": "get_a_hash_report_",
      "parameters": [
        {
          "name": "resource",
          "value": "$exec.body.syscheck.sha256_after"
        }
      ],
      "position": {
        "x": 0,
        "y": 200
      }
    },
    {
      "id": "faaeb06d-3edc-4d4c-aef8-8459ca614d6b",
      "name": "post_create_alert",
      "label": "Create TheHive Alert",
      "app_name": "TheHive5",
      "app_version": "1.1.0",
      "app_id": "52052963557bbecd0d85a92b848da4ca",
      "action": "post_create_alert",
      "parameters": [
        {
          "name": "title",
          "value": "Malicious Hash Detected"
        },
        {
          "name": "description",
          "value": "A malicious hash was detected by VirusTotal."
        },
        {
          "name": "type",
          "value": "external"
        },
        {
          "name": "source",
          "value": "VirusTotal"
        },
        {
          "name": "sourceRef",
          "value": "$exec.body.syscheck.sha256_after"
        },
        {
          "name": "severity",
          "value": "high"
        },
        {
          "name": "tlp",
          "value": 2
        },
        {
          "name": "tags",
          "value": "malicious, hash"
        }
      ],
      "position": {
        "x": 0,
        "y": 400
      }
    }
  ],
  "branches": [
    {
      "id": "branch_1",
      "source_id": "8875af4a-eeee-406f-a10b-362fa203badd",
      "destination_id": "faaeb06d-3edc-4d4c-aef8-8459ca614d6b",
      "label": "malicious",
      "has_errors": false,
      "conditions": [
        {
          "condition": {
            "source": {
              "type": "value",
              "value": "$get_a_hash_report_.data.attributes.last_analysis_stats.malicious"
            },
            "operator": "LARGER_THAN",
            "destination": {
              "type": "value",
              "value": "0"
            }
          }
        }
      ]
    }
  ]
}