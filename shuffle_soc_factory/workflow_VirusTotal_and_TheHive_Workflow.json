{
  "name": "VirusTotal and TheHive Workflow",
  "description": "Analyze a file hash with VirusTotal and create an alert in TheHive if malicious.",
  "start": "webhook_trigger",
  "triggers": [
    {
      "id": "webhook_trigger",
      "name": "Wazuh Webhook",
      "app_name": "Shuffle Tools",
      "app_version": "1.2.0",
      "trigger_type": "WEBHOOK",
      "label": "Wazuh Alert Webhook",
      "status": "running"
    }
  ],
  "actions": [
    {
      "id": "bee64ce7-915b-45b5-a657-27e7b77e0bf6",
      "name": "get_a_hash_report_",
      "label": "Check VirusTotal",
      "app_name": "Virustotal_v3",
      "app_version": "1.1.0",
      "app_id": "fa9d7dd6d5e501798870c9451611817f",
      "action": "get_a_hash_report_",
      "parameters": [
        {
          "name": "resource",
          "value": "$exec.body.syscheck.sha256_after"
        }
      ],
      "position": {
        "x": 0,
        "y": 200
      }
    },
    {
      "id": "e6f0de7c-2b1f-47c9-a8a3-7d8eb120c578",
      "name": "post_create_case_from_alert",
      "label": "Create TheHive Alert",
      "app_name": "TheHive5",
      "app_version": "1.1.0",
      "app_id": "52052963557bbecd0d85a92b848da4ca",
      "action": "post_create_case_from_alert",
      "parameters": [
        {
          "name": "title",
          "value": "Malicious File Detected on $exec.body.agent.name"
        },
        {
          "name": "severity",
          "value": "3"
        }
      ],
      "position": {
        "x": 0,
        "y": 400
      }
    }
  ],
  "branches": [
    {
      "id": "branch_malicious",
      "source_id": "bee64ce7-915b-45b5-a657-27e7b77e0bf6",
      "destination_id": "e6f0de7c-2b1f-47c9-a8a3-7d8eb120c578",
      "label": "malicious",
      "has_errors": false,
      "conditions": [
        {
          "condition": {
            "source": {
              "type": "value",
              "value": "$get_a_hash_report_.data.attributes.last_analysis_stats.malicious"
            },
            "operator": "LARGER_THAN",
            "destination": {
              "type": "value",
              "value": "0"
            }
          }
        }
      ]
    }
  ]
}